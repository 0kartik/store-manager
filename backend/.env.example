# Postgres connection string (Supabase "Connection string" / URI, or local Postgres)
DATABASE_URL=postgresql://user:password@host:port/database

# Any long random string — used to sign JWTs
JWT_SECRET=replace_with_a_long_random_string

# Optional — how long login tokens stay valid. Defaults to 7d if not set.
JWT_EXPIRES_IN=7d

# Optional — port the Express server listens on. Defaults to 5000 if not set.
PORT=5000
